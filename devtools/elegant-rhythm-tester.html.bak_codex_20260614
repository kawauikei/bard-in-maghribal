// Init Audio Pool (CORS-free)
function initAudioPool() {
    if (sePool.length === 0) {
        for (let i = 0; i < SE_POOL_SIZE; i++) {
            const audioObj = new Audio(SE_FILE_PATH);
            audioObj.volume = parseFloat(seVol.value) / 100;
            sePool.push(audioObj);
        }
    }
}

function playTapSE() {
    initAudioPool();
    if (sePool.length === 0) return;
    
    const audio = sePool[sePoolIndex];
    audio.volume = parseFloat(seVol.value) / 100;
    audio.currentTime = 0;
    audio.play().catch(e => {
        console.log("SE audio play blocked or loading:", e.message);
    });
    sePoolIndex = (sePoolIndex + 1) % SE_POOL_SIZE;
}

// Controls Listeners
bgmVol.addEventListener('input', (e) => {
    const vol = e.target.value;
    bgmVolVal.textContent = `${vol}%`;
    player.volume = vol / 100;
});

seVol.addEventListener('input', (e) => {
    seVolVal.textContent = `${e.target.value}%`;
});

offsetInput.addEventListener('input', (e) => {
    const val = e.target.value;
    offsetVal.textContent = `${val > 0 ? '+' : ''}${val} ms`;
});

speedInput.addEventListener('input', (e) => {
    noteSpeed = parseInt(e.target.value, 10);
    speedVal.textContent = `${noteSpeed} px/s`;
});

// Layout Resizing
function handleResize() {
    const container = document.getElementById('game-container');
    const scale = Math.min(window.innerWidth / 1920, window.innerHeight / 1080);
    container.style.transform = `scale(${scale})`;
}

window.addEventListener('resize', handleResize);

function populateSelect() {
    trackSelect.innerHTML = '';
    tracksData.forEach((t, i) => {
        const opt = document.createElement('option');
        opt.value = i;
        const nameMatch = t.id.match(/^song_[\d_]+(.*)$/);
        const dispName = nameMatch ? nameMatch[1] : t.id;
        opt.textContent = dispName;
        trackSelect.appendChild(opt);
    });
}

function selectTrack(idx) {
    if (!tracksData[idx]) return;
    const track = tracksData[idx];
    
    const fileName = (track.generated && track.generated.length > 0) ? track.generated[0] : track.id + '.mp3';
    const baseName = fileName.replace(/\.mp3$/, '');
    
    player.src = AUDIO_BASE_DIR + encodeURIComponent(fileName);
    player.load();
    player.volume = bgmVol.value / 100;
    document.getElementById('vocal-tag').textContent = baseName.replace(/^song_[\d_]+/, '');
    
    const emoData = songEmotionsData[baseName] || { attribute: "brave", emotion: "neutral" };
    loadPortraitSprite(emoData.attribute, emoData.emotion);
}

trackSelect.addEventListener('change', (e) => {
    selectTrack(parseInt(e.target.value, 10));
});

function loadTracks() {
    if (typeof tracks !== 'undefined' && tracks.length > 0) {
        tracksData = tracks;
    }
    if (typeof songEmotions !== 'undefined') {
        songEmotionsData = songEmotions;
    }
    populateSelect();
    if (tracksData.length > 0) selectTrack(0);
}

// --- Portrait Rendering (Fully aligned with vocal.html specification) ---
let spriteImg = new Image();
let spriteCanvas = document.getElementById('vocal-canvas');
let spriteCtx = spriteCanvas.getContext('2d');
let spriteFrame = 0;
let spriteAnimId;

// State Logic from vocal.html
let activeState = 'BGM'; // BGM, VOCAL, CHORUS, VOCAL_UP
let selectedRow = 0;     // 0: BGM, 1: VOCAL, 2: CHORUS, 3: VOCAL_UP
let selectedCol = 0;     // random index 0-7
let lastStateCols = { BGM: 0, VOCAL: 0, CHORUS: 0, VOCAL_UP: 0 };
let lastReselectTime = 0;
let spriteCols = 8;
let cellWidth = 0;
let cellHeight = 0;
let currentSpriteLoaded = false;

// Transition state from vocal.html (Default transition is Slide/Wipe)
let isTransitioning = false;
let transSourceCell = { row: 0, col: 0 };
let transTargetCell = { row: 0, col: 0 };
let transStartTime = 0;
let transProgress = 0.0;
let transMode = 'wipe'; // Default to Slide (Wipe) as requested

function loadPortraitSprite(attr, emo) {
    cancelAnimationFrame(spriteAnimId);
    currentSpriteLoaded = false;
    spriteImg = new Image();
    spriteImg.src = `${SPRITE_BASE_DIR}vocal_sprite_${attr}_${emo}_8x4.webp`;
    
    spriteImg.onload = () => {
        currentSpriteLoaded = true;
        spriteCanvas.width = 300;
        spriteCanvas.height = 410;
        spriteCols = 8;
        cellWidth = spriteImg.width / 8;
        cellHeight = spriteImg.height / 4;
        selectedRow = 0;
        selectedCol = 0;
        isTransitioning = false;
        
        lastReselectTime = Date.now();
        drawSpriteFrame();
    };
    
    spriteImg.onerror = () => {
        if (attr !== "brave" || emo !== "neutral") {
            loadPortraitSprite("brave", "neutral");
        }
    };
}

function getRawStateAtTime(time) {
    if (!isPlaying || isPaused) return 'BGM';
    const trackIdx = parseInt(trackSelect.value, 10);
    const track = tracksData[trackIdx];
    if (!track) return 'BGM';
    
    const fileName = (track.generated && track.generated.length > 0) ? track.generated[0] : track.id + '.mp3';
    
    const singingIntervals = track.singingIntervals && track.singingIntervals[fileName] || [];
    const excSegs = track.excitementSegments && track.excitementSegments[fileName] || [];
    const chorusSegs = track.chorusCandidates && track.chorusCandidates[fileName] || [];
    
    const isSinging = singingIntervals.some(r => time >= r[0] && time <= r[1]);
    const isExcited = excSegs.some(r => time >= r[0] && time <= r[1]);
    const isChorus = chorusSegs.some(r => time >= r[0] && time <= r[1]);
    
    if (isSinging && isExcited) return 'VOCAL_UP';
    if (isSinging) return 'VOCAL';
    if (isChorus) return 'CHORUS';
    return 'BGM';
}

function triggerRandomCellForState(state) {
    const stateToRow = { 'BGM': 0, 'VOCAL': 1, 'CHORUS': 2, 'VOCAL_UP': 3 };
    const row = stateToRow[state];
    let col = Math.floor(Math.random() * spriteCols);
    
    let attempts = 0;
    const prevColForState = lastStateCols[state];
    while ((col === selectedCol || col === prevColForState) && attempts < 10) {
        col = Math.floor(Math.random() * spriteCols);
        attempts++;
    }
    
    lastStateCols[state] = col;
    startTransitionTo(row, col);
    lastReselectTime = Date.now();
}

function startTransitionTo(row, col) {
    if (row === selectedRow && col === selectedCol) return;
    
    transSourceCell = { row: selectedRow, col: selectedCol };
    transTargetCell = { row, col };
    transProgress = 0.0;
    transStartTime = Date.now();
    isTransitioning = true;
}

function drawCell(cell, alpha, xOffset = 0, yOffsetExt = 0) {
    spriteCtx.save();
    spriteCtx.globalAlpha = alpha;
    
    const sx = cell.col * cellWidth;
    const sy = cell.row * cellHeight;
    const aspect = cellWidth / cellHeight;
    
    const baseScale = 1.15; // 15% zoom in to cover borders during bobbing/scaling
    const cw = spriteCanvas.width;
    const ch = spriteCanvas.height;
    let dw = cw * baseScale;
    let dh = ch * baseScale;
    
    if (cw / ch > aspect) {
        dw = ch * aspect * baseScale;
    } else {
        dh = (cw / aspect) * baseScale;
    }
    
    let scaleMultiplier = 1.0;
    let yOffset = yOffsetExt;
    
    if (isPlaying && !player.paused && !isCountingDown) {
        const trackIdx = parseInt(trackSelect.value, 10);
        const track = tracksData[trackIdx];
        if (track) {
            const fileName = (track.generated && track.generated.length > 0) ? track.generated[0] : track.id + '.mp3';
            let bpm = 120;
            if (track.bpms && track.bpms[fileName]) {
                bpm = track.bpms[fileName];
            }
            const beatDuration = 60 / bpm;
            const elapsedBeats = player.currentTime / beatDuration;
            const beatProgress = elapsedBeats % 1.0;
            
            let targetStrength = 0.25;
            if (activeState === 'VOCAL' || activeState === 'VOCAL_UP') {
                const maxStrengthByBpm = 0.5 + (0.75 - 0.5) * Math.min(1.0, Math.max(0.0, (bpm - 80) / 50));
                targetStrength = maxStrengthByBpm;
            }
            const strength = targetStrength;
            
            const maxScale = 0.05 * strength * (2/3); 
            const maxBob = dh * (10 / 300) * strength * (2/3);
            
            scaleMultiplier = 1.0 + maxScale * Math.exp(-beatProgress * 8);
            yOffset += maxBob * Math.sin(beatProgress * Math.PI);
        }
    }
    
    dw *= scaleMultiplier;
    dh *= scaleMultiplier;
    const dx = (cw - dw) / 2 + xOffset;
    const dy = (ch - dh) / 2 + yOffset;
    
    spriteCtx.imageSmoothingEnabled = true;
    spriteCtx.drawImage(spriteImg, sx, sy, cellWidth, cellHeight, dx, dy, dw, dh);
    spriteCtx.restore();
}

function drawSpriteFrame() {
    if (!currentSpriteLoaded || !spriteImg.complete) return;
    
    const cw = spriteCanvas.width;
    const ch = spriteCanvas.height;
    
    spriteCtx.clearRect(0, 0, cw, ch);
    spriteCtx.fillStyle = '#f4ecd8';
    spriteCtx.fillRect(0, 0, cw, ch);
    
    const now = Date.now();
    
    if (isPlaying && !isPaused && !isCountingDown) {
        const curTime = player.currentTime;
        const targetState = getRawStateAtTime(curTime);
        
        if (targetState !== activeState) {
            activeState = targetState;
            triggerRandomCellForState(activeState);
        }
        
        let bpm = 120;
        const trackIdx = parseInt(trackSelect.value, 10);
        const track = tracksData[trackIdx];
        if (track) {
            const fileName = (track.generated && track.generated.length > 0) ? track.generated[0] : track.id + '.mp3';
            if (track.bpms && track.bpms[fileName]) bpm = track.bpms[fileName];
        }
        const tBpm = Math.min(1.0, Math.max(0.0, (bpm - 80) / 50));
        const intervalMs = (5.0 - 2.0 * tBpm) * 1000;
        
        if (now - lastReselectTime >= intervalMs && !isTransitioning) {
            triggerRandomCellForState(activeState);
        }
    }
    
    if (isTransitioning) {
        const duration = 200; 
        const elapsed = now - transStartTime;
        transProgress = Math.min(1.0, elapsed / duration);
        
        if (transMode === 'wipe') {
            // Slide transition from vocal.html
            const sourceXOffset = -cw * transProgress;
            const targetXOffset = cw - (cw * transProgress);
            drawCell(transSourceCell, 1.0, sourceXOffset);
            drawCell(transTargetCell, 1.0, targetXOffset);
        } else if (transMode === 'dip') {
            if (elapsed >= duration / 2) {
                if (selectedRow !== transTargetCell.row || selectedCol !== transTargetCell.col) {
                    selectedRow = transTargetCell.row;
                    selectedCol = transTargetCell.col;
                }
            }
            if (transProgress < 0.5) {
                const alpha = 1.0 - (transProgress / 0.5);
                drawCell(transSourceCell, alpha);
            } else {
                const alpha = (transProgress - 0.5) / 0.5;
                drawCell(transTargetCell, alpha);
            }
        } else {
            drawCell(transTargetCell, 1.0);
        }
        
        if (transProgress >= 1.0) {
            isTransitioning = false;
            selectedRow = transTargetCell.row;
            selectedCol = transTargetCell.col;
        }
    } else {
        drawCell({ row: selectedRow, col: selectedCol }, 1.0);
    }
    
    spriteAnimId = requestAnimationFrame(drawSpriteFrame);
}

// --- Canvas Visualizer ---
const vizCanvas = document.getElementById('visualizer-canvas');
const vizCtx = vizCanvas.getContext('2d');
let vizAnimId;
let visualBeats = [];
let lightBeams = { mystic: 0, elegant: 0, brave: 0 };

function resizeVizCanvas() {
    vizCanvas.width = vizCanvas.clientWidth;
    vizCanvas.height = vizCanvas.clientHeight;
}
window.addEventListener('resize', resizeVizCanvas);

function startVisualizer() {
    resizeVizCanvas();
    drawVisualizer();
}

function drawVisualizer() {
    vizCtx.clearRect(0, 0, vizCanvas.width, vizCanvas.height);
    
    const w = vizCanvas.width;
    const h = vizCanvas.height;
    
    vizCtx.strokeStyle = 'rgba(255, 255, 255, 0.02)';
    vizCtx.lineWidth = 1;
    for (let x = 0; x < w; x += 40) {
        vizCtx.beginPath(); vizCtx.moveTo(x, 0); vizCtx.lineTo(x, h); vizCtx.stroke();
    }
    
    let isSinging = (activeState === 'VOCAL' || activeState === 'VOCAL_UP');
    
    const waveCount = 3;
    const colors = [
        'rgba(16, 185, 129, 0.3)', // mystic
        'rgba(168, 85, 247, 0.3)', // elegant
        'rgba(239, 68, 68, 0.3)'   // brave
    ];
    
    if (isPlaying && !player.paused) {
        const time = performance.now() * 0.004;
        const speedFactor = isSinging ? 2 : 0.8;
        const ampFactor = isSinging ? 80 : 30;
        
        for (let i = 0; i < waveCount; i++) {
            vizCtx.beginPath();
            vizCtx.strokeStyle = colors[i];
            vizCtx.lineWidth = isSinging ? 4 - i : 2;
            
            for (let x = 0; x < w; x++) {
                const y = h / 2 + 
                          Math.sin(x * 0.005 + time * speedFactor + i) * ampFactor * Math.sin(x/w * Math.PI) + 
                          Math.sin(x * 0.015 - time * 0.5 * speedFactor + i * 2) * (ampFactor * 0.3);
                if (x === 0) vizCtx.moveTo(x, y);
                else vizCtx.lineTo(x, y);
            }
            vizCtx.stroke();
        }
    } else {
        vizCtx.beginPath();
        vizCtx.strokeStyle = 'rgba(255, 255, 255, 0.1)';
        vizCtx.lineWidth = 1;
        vizCtx.moveTo(0, h/2);
        vizCtx.lineTo(w, h/2);
        vizCtx.stroke();
    }
    
    if (isSinging && Math.random() < 0.15 && !isCountingDown) {
        visualBeats.push({
            x: w / 2 + (Math.random() - 0.5) * 100,
            y: h / 2 + (Math.random() - 0.5) * 60,
            vx: (Math.random() - 0.5) * 4,
            vy: (Math.random() - 0.7) * 5,
            size: Math.random() * 8 + 4,
            alpha: 1,
            color: colors[Math.floor(Math.random() * colors.length)],
            char: ['♪', '♫', '♩', '♬'][Math.floor(Math.random() * 4)]
        });
    }
    
    for (let i = visualBeats.length - 1; i >= 0; i--) {
        const p = visualBeats[i];
        p.x += p.vx;
        p.y += p.vy;
        p.alpha -= 0.015;
        if (p.alpha <= 0) {
            visualBeats.splice(i, 1);
            continue;
        }
        vizCtx.save();
        vizCtx.globalAlpha = p.alpha;
        vizCtx.fillStyle = p.color;
        vizCtx.font = `${p.size * 2}px sans-serif`;
        vizCtx.fillText(p.char, p.x, p.y);
        vizCtx.restore();
    }
    
    const judgmentX = w * JUDGMENT_X_RATIO;
    const beamColors = {
        mystic: 'rgba(16, 185, 129, ',
        elegant: 'rgba(168, 85, 247, ',
        brave: 'rgba(239, 68, 68, '
    };
    
    Object.keys(lightBeams).forEach((attr, idx) => {
        if (lightBeams[attr] > 0) {
            lightBeams[attr] -= 0.05;
            const alpha = lightBeams[attr];
            const x = judgmentX - (idx * 30);
            const grad = vizCtx.createLinearGradient(x, h, x, 0);
            grad.addColorStop(0, beamColors[attr] + alpha * 0.4 + ')');
            grad.addColorStop(1, beamColors[attr] + '0)');
            
            vizCtx.fillStyle = grad;
            vizCtx.fillRect(x - 30, 0, 60, h);
        }
    });
    
    vizAnimId = requestAnimationFrame(drawVisualizer);
}

function triggerBeam(attr) {
    lightBeams[attr] = 1.0;
}

// --- Particle Sparkles ---
function spawnParticles(x, y, color) {
    const laneContainer = document.getElementById('lane-container');
    const particleCount = 12;
    for (let i = 0; i < particleCount; i++) {
        const sparkle = document.createElement('div');
        sparkle.className = 'sparkle';
        sparkle.style.left = `${x}px`;
        sparkle.style.top = `${y}px`;
        sparkle.style.backgroundColor = color;
        sparkle.style.boxShadow = `0 0 8px ${color}`;
        
        const angle = Math.random() * Math.PI * 2;
        const distance = Math.random() * 80 + 30;
        const tx = Math.cos(angle) * distance;
        const ty = Math.sin(angle) * distance;
        
        sparkle.style.setProperty('--tx', `${tx}px`);
        sparkle.style.setProperty('--ty', `${ty}px`);
        
        laneContainer.appendChild(sparkle);
        setTimeout(() => sparkle.remove(), 400);
    }
}

function spawnHitRing(x, y, color) {
    const laneContainer = document.getElementById('lane-container');
    const ring = document.createElement('div');
    ring.className = 'hit-ring';
    ring.style.left = `${x}px`;
    ring.style.top = `${y}px`;
    ring.style.borderColor = color;
    ring.style.boxShadow = `0 0 15px ${color}`;
    
    laneContainer.appendChild(ring);
    setTimeout(() => ring.remove(), 300);
}

// --- Game Logic ---

playBtn.addEventListener('click', () => {
    initAudioPool();
    if (isPlaying) {
        stopGame();
    } else {
        startGame();
    }
});

function startGame() {
    const trackIdx = parseInt(trackSelect.value, 10);
    if (isNaN(trackIdx) || !tracksData[trackIdx]) return;
    
    const track = tracksData[trackIdx];
    const density = document.getElementById('density-select').value;
    
    const fileName = (track.generated && track.generated.length > 0) ? track.generated[0] : track.id + '.mp3';
    const fileNotes = track.notes && track.notes[fileName] ? track.notes[fileName] : {};
    const densityNotes = fileNotes[density] || [];
    
    currentNotes = densityNotes.map(n => ({...n, hit: false, missed: false}));

    score = 0; combo = 0; maxCombo = 0;
    perfects = 0; greats = 0; goods = 0; misses = 0;
    updateHUD();
    notesLayer.innerHTML = '';
    
    isPlaying = true;
    isPaused = false;
    isCountingDown = true;
    playBtn.textContent = 'STOP';
    
    activeState = 'BGM';
    selectedRow = 0;
    selectedCol = 0;
    isTransitioning = false;
    lastReselectTime = Date.now();
    
    // Set countdown start
    gameStartTime = performance.now();
    gameTime = -3.0; 
    
    // Start game loop immediately (notes will slide in during countdown)
    requestAnimationFrame(updateGameLoop);
}

function stopGame() {
    isPlaying = false;
    isPaused = false;
    isCountingDown = false;
    playBtn.textContent = 'PLAY';
    player.pause();
    notesLayer.innerHTML = '';
    document.getElementById('countdown-overlay').style.display = 'none';
    pauseModal.classList.remove('active');
    resultsModal.classList.remove('active');
    
    activeState = 'BGM';
    selectedRow = 0;
    selectedCol = 0;
    isTransitioning = false;
}

function pauseGame() {
    if (!isPlaying || isPaused || isCountingDown) return;
    isPaused = true;
    player.pause();
    
    document.getElementById('pause-score').textContent = score;
    document.getElementById('pause-combo').textContent = combo;
    pauseModal.classList.add('active');
}

function resumeGame() {
    if (!isPlaying || !isPaused) return;
    isPaused = false;
    pauseModal.classList.remove('active');
    player.play();
    requestAnimationFrame(updateGameLoop);
}

// Modal Actions
document.getElementById('resume-btn').addEventListener('click', resumeGame);
document.getElementById('restart-btn').addEventListener('click', () => {
    stopGame();
    startGame();
});
document.getElementById('exit-btn').addEventListener('click', stopGame);

document.getElementById('res-retry-btn').addEventListener('click', () => {
    resultsModal.classList.remove('active');
    startGame();
});
document.getElementById('res-close-btn').addEventListener('click', () => {
    resultsModal.classList.remove('active');
    stopGame();
});

function updateHUD() {
    scoreValEl.textContent = score;
    comboValEl.textContent = combo;
    timeValEl.textContent = Math.max(0, gameTime).toFixed(2);
}

function showHitFeedback(text, color, yPos) {
    const feedback = document.createElement('div');
    feedback.className = 'hit-text';
    feedback.textContent = text;
    feedback.style.color = color;
    feedback.style.textShadow = `0 0 20px ${color}`;
    
    // Position alignment
    feedback.style.top = yPos;
    feedback.style.left = '75%';
    
    document.getElementById('lane-container').appendChild(feedback);
    setTimeout(() => {
        feedback.remove();
    }, 500);
}

function handleMiss() {
    combo = 0;
    misses++;
    updateHUD();
    
    // Position alignment for miss
    showHitFeedback('MISS', '#ef4444', '50%');
}

function triggerInput(attribute) {
    if (!isPlaying || isPaused || isCountingDown) return;
    
    triggerBeam(attribute);
    
    const btn = document.querySelector(`.input-btn.${attribute}`);
    if (btn) {
        btn.classList.add('active');
        setTimeout(() => btn.classList.remove('active'), 80);
    }
    
    const offsetMs = parseInt(offsetInput.value, 10);
    const currentTime = gameTime - (offsetMs / 1000);
    const windowMs = parseInt(document.getElementById('window-select').value, 10) / 1000;
    
    let closestNote = null;
    let closestDiff = Infinity;
    
    for (const note of currentNotes) {
        if (!note.hit && !note.missed && note.attribute === attribute) {
            const diff = Math.abs(note.time - currentTime);
            if (diff < windowMs && diff < closestDiff) {
                closestDiff = diff;
                closestNote = note;
            }
        }
    }
    
    if (closestNote) {
        // Sound SE ONLY triggers when a note is successfully hit (no empty click noises)
        playTapSE();
        
        closestNote.hit = true;
        
        let points = 0;
        let text = '';
        let color = '';
        
        if (closestDiff < windowMs * 0.3) {
            points = 100; text = 'PERFECT'; color = '#fbbf24'; perfects++;
        } else if (closestDiff < windowMs * 0.6) {
            points = 50; text = 'GREAT'; color = '#34d399'; greats++;
        } else {
            points = 10; text = 'GOOD'; color = '#38bdf8'; goods++;
        }
        
        score += points;
        combo++;
        if (combo > maxCombo) maxCombo = combo;
        
        comboValEl.classList.remove('bump');
        void comboValEl.offsetWidth; 
        comboValEl.classList.add('bump');
        
        updateHUD();
        
        const laneContainer = document.getElementById('lane-container');
        const laneWidth = laneContainer.clientWidth;
        const judgmentX = laneWidth * JUDGMENT_X_RATIO;
        
        let yPosPct = '50%';
        let yPosVal = 0;
        if (attribute === 'brave') { yPosPct = '85%'; yPosVal = laneContainer.clientHeight * 0.85; }
        if (attribute === 'elegant') { yPosPct = '50%'; yPosVal = laneContainer.clientHeight * 0.50; }
        if (attribute === 'mystic') { yPosPct = '15%'; yPosVal = laneContainer.clientHeight * 0.15; }
        
        // Show hit text feedback aligned strictly to the specific lane's Y position
        showHitFeedback(text, color, yPosPct);
        
        spawnHitRing(judgmentX, yPosVal, color);
        spawnParticles(judgmentX, yPosVal, color);
        
        if (closestNote.domElement) {
            closestNote.domElement.remove();
        }
    }
}

// Input bindings
document.querySelectorAll('.input-btn').forEach(btn => {
    btn.addEventListener('contextmenu', e => e.preventDefault());
    btn.addEventListener('mousedown', (e) => {
        e.preventDefault();
        triggerInput(btn.getAttribute('data-attr'));
    });
});

const gameContainer = document.getElementById('game-container');

// Easy mouse click handling
gameContainer.addEventListener('mousedown', e => {
    if (easyMouseSelect.value === 'off' || !isPlaying || isPaused || isCountingDown) return;
    if (e.target.closest('select') || e.target.closest('button') || e.target.closest('input') || e.target.closest('.input-btn')) return;
    
    if (e.button === 0) triggerInput('brave');   // Left click -> Brave
    if (e.button === 1) triggerInput('mystic');  // Middle click (wheel click) -> Mystic
    if (e.button === 2) triggerInput('elegant'); // Right click -> Elegant
});

// Suppress right-click context menu when Easy Mouse Input is ON
gameContainer.addEventListener('contextmenu', e => {
    if (easyMouseSelect.value === 'on') {
        if (!e.target.closest('select') && !e.target.closest('button') && !e.target.closest('input')) {
            e.preventDefault();
        }
    }
});

// Wheel Up -> Mystic
gameContainer.addEventListener('wheel', e => {
    if (easyMouseSelect.value === 'off' || !isPlaying || isPaused || isCountingDown) return;
    if (e.target.closest('select') || e.target.closest('button') || e.target.closest('input')) return;
    
    if (e.deltaY < 0) {
        triggerInput('mystic');
    }
});

// Keyboards input completely disabled. Only pause via Escape is supported.
document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
        if (isPlaying) {
            if (isPaused) resumeGame();
            else pauseGame();
        }
    }
});

function displayResults() {
    isPlaying = false;
    playBtn.textContent = 'PLAY';
    
    const totalNotes = perfects + greats + goods + misses;
    const maxScore = totalNotes * 100;
    const ratio = maxScore > 0 ? (score / maxScore) : 0;
    
    let rank = 'D';
    if (ratio >= 0.95) rank = 'S';
    else if (ratio >= 0.85) rank = 'A';
    else if (ratio >= 0.70) rank = 'B';
    else if (ratio >= 0.50) rank = 'C';
    
    const rankEl = document.getElementById('res-rank');
    rankEl.textContent = rank;
    rankEl.className = `result-rank rank-${rank}`;
    
    document.getElementById('res-perfect').textContent = perfects;
    document.getElementById('res-great').textContent = greats;
    document.getElementById('res-good').textContent = goods;
    document.getElementById('res-miss').textContent = misses;
    document.getElementById('res-maxcombo').textContent = maxCombo;
    document.getElementById('res-score').textContent = score;
    
    resultsModal.classList.add('active');
}

function updateGameLoop() {
    if (!isPlaying || isPaused) return;
    
    const now = performance.now();
    
    // Countdown / GameTime Management
    if (isCountingDown) {
        gameTime = (now - gameStartTime) / 1000 - 3.0; // from -3.0 to 0
        
        const overlay = document.getElementById('countdown-overlay');
        const text = document.getElementById('countdown-text');
        overlay.style.display = 'flex';
        
        if (gameTime < -2.0) {
            text.textContent = "3";
        } else if (gameTime < -1.0) {
            text.textContent = "2";
        } else if (gameTime < 0) {
            text.textContent = "1";
        } else {
            // Reached 0: start song!
            text.textContent = "START!";
            isCountingDown = false;
            player.currentTime = 0;
            player.play();
            gameTime = 0;
        }
    } else {
        // Hide countdown overlay after 1 second past start
        if (player.currentTime < 1.0) {
            document.getElementById('countdown-overlay').style.display = 'flex';
            document.getElementById('countdown-text').textContent = "START!";
        } else {
            document.getElementById('countdown-overlay').style.display = 'none';
        }
        gameTime = player.currentTime;
    }
    
    updateHUD();
    
    const lookahead = 2.0; 
    const laneContainer = document.getElementById('lane-container');
    const laneWidth = laneContainer.clientWidth;
    const judgmentX = laneWidth * JUDGMENT_X_RATIO;
    
    currentNotes.forEach(note => {
        if (!note.hit && !note.missed && note.time <= gameTime + lookahead) {
            if (!note.domElement) {
                const noteDiv = document.createElement('div');
                noteDiv.className = `note ${note.attribute}`;
                
                let bgPos = '';
                if (note.attribute === 'brave') { noteDiv.style.top = '85%'; bgPos = '0% 42.857%'; }
                if (note.attribute === 'elegant') { noteDiv.style.top = '50%'; bgPos = '14.285% 42.857%'; }
                if (note.attribute === 'mystic') { noteDiv.style.top = '15%'; bgPos = '28.571% 42.857%'; }

                let shapeChar = '';
                if (note.attribute === 'mystic') shapeChar = '■';
                if (note.attribute === 'elegant') shapeChar = '●';
                if (note.attribute === 'brave') shapeChar = '★';

                noteDiv.innerHTML = `
                    <div class="note-shape">${shapeChar}</div>
                    <div class="note-icon" style="background-position: ${bgPos};"></div>
                `;

                notesLayer.appendChild(noteDiv);
                note.domElement = noteDiv;
            }
            
            // Move: left to right (judgmentX is target at left 75%)
            const deltaT = note.time - gameTime;
            const noteX = judgmentX - (deltaT * noteSpeed);
            
            note.domElement.style.left = `${noteX}px`;
            
            // Miss check (passed the judgment line by a margin)
            // (Only check miss when the countdown has finished and song is playing)
            if (gameTime >= 0 && noteX > laneWidth + 100) {
                note.missed = true;
                note.domElement.remove();
                handleMiss();
            }
        }
    });
    
    if (gameTime >= 0 && (player.ended || (currentNotes.length > 0 && currentNotes.every(n => n.hit || n.missed)))) {
        setTimeout(() => {
            if (isPlaying) { 
                displayResults();
            }
        }, 1000);
    } else {
        requestAnimationFrame(updateGameLoop);
    }
}

// Retrying loadTracks if rhythm_data.js loading is delayed (prevents empty dropdowns)
function tryLoadTracks() {
    if (typeof tracks !== 'undefined' && tracks.length > 0) {
        loadTracks();
    } else {
        setTimeout(tryLoadTracks, 100);
    }
}

window.onload = () => {
    handleResize();
    tryLoadTracks();
    startVisualizer();
};

</script>
