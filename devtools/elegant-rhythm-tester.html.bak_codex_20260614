<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Elegant Rhythm Tester</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800&family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet">
<style>
    :root {
        --c-brave: #ef4444;    
        --c-elegant: #a855f7;  
        --c-mystic: #10b981;   
        --bg-dark: #0f172a;
        --glass-bg: rgba(15, 23, 42, 0.75);
        --glass-border: rgba(255, 255, 255, 0.1);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        background: #020617;
        color: #fff;
        font-family: 'Outfit', 'Noto Sans JP', sans-serif;
        overflow: hidden;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        user-select: none;
    }
    
    #game-container {
        width: 1920px;
        height: 1080px;
        background: radial-gradient(circle at 50% 50%, #0f172a 0%, #020617 100%);
        border: 2px solid var(--glass-border);
        position: relative;
        transform-origin: center;
        display: flex;
        flex-direction: column;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        overflow: hidden;
    }

    /* Top Half: Visualizer & Particle Effects */
    #top-half {
        height: 480px;
        border-bottom: 2px solid var(--glass-border);
        position: relative;
        background: rgba(2, 6, 23, 0.5);
        overflow: hidden;
    }
    
    #visualizer-canvas {
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        z-index: 1;
        pointer-events: none;
    }

    #visual-overlay-text {
        position: absolute;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 14px;
        letter-spacing: 3px;
        color: rgba(255, 255, 255, 0.2);
        z-index: 2;
        font-weight: 600;
        text-transform: uppercase;
    }

    #bottom-half {
        flex-grow: 1;
        display: flex;
        position: relative;
        padding: 40px;
        background: rgba(15, 23, 42, 0.2);
    }

    /* Left: Vocal Portrait (Exactly aligned bottom-left) */
    #vocal-portrait-container {
        width: 320px;
        height: 460px;
        background: #f4ecd8; /* parchment background */
        border: 2px solid var(--glass-border);
        border-radius: 20px;
        position: relative;
        z-index: 10;
        box-shadow: 0 10px 30px rgba(0,0,0,0.6);
        overflow: hidden;
        margin-top: auto;
        margin-bottom: 0;
    }
    
    #vocal-canvas {
        width: 100%;
        height: calc(100% - 50px);
        background: #f4ecd8;
    }

    .vocal-name {
        height: 50px;
        line-height: 50px;
        text-align: center;
        background: #0f172a;
        font-weight: 800;
        font-size: 18px;
        letter-spacing: 1px;
        border-top: 1px solid var(--glass-border);
        color: #e2e8f0;
    }

    /* Lanes Area */
    #lane-container {
        flex-grow: 1;
        position: relative;
        margin-left: 40px;
        z-index: 5;
    }

    /* 3 Lanes background paths */
    .lane-path {
        position: absolute;
        left: 0;
        height: 4px;
        background: linear-gradient(to right, rgba(255,255,255,0.02), rgba(255,255,255,0.1) 70%, rgba(255,255,255,0.2) 75%, rgba(255,255,255,0.05));
        z-index: 1;
        border-radius: 2px;
    }
    
    /* Straight lanes */
    .lane-path.mystic { top: 15%; width: 95%; box-shadow: 0 0 8px rgba(16, 185, 129, 0.1); }
    .lane-path.elegant { top: 50%; width: 90%; box-shadow: 0 0 8px rgba(168, 85, 247, 0.1); }
    .lane-path.brave { top: 85%; width: 85%; box-shadow: 0 0 8px rgba(239, 68, 68, 0.1); }

    /* Single Vertical Judgment Line at 75% */
    #judgment-line {
        position: absolute;
        left: 75%;
        top: 5%; bottom: 5%;
        width: 4px;
        background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.9) 30%, rgba(255,255,255,0.9) 70%, transparent);
        z-index: 2;
        box-shadow: 0 0 20px rgba(255,255,255,0.6);
        pointer-events: none;
    }

    /* Buttons positioned directly to the right of the Judgment Line (Y matches lane top) */
    .input-btn {
        position: absolute;
        width: 90px;
        height: 90px;
        border-radius: 50%;
        border: 3px solid rgba(255,255,255,0.4);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 30;
        background: rgba(15, 23, 42, 0.9);
        cursor: pointer;
        transition: transform 0.05s, box-shadow 0.05s, border-color 0.1s;
        box-shadow: 0 4px 10px rgba(0,0,0,0.5);
    }
    
    .input-btn:active, .input-btn.active {
        transform: scale(0.9);
    }

    .input-btn.mystic { top: calc(15% - 45px); left: 80%; border-color: var(--c-mystic); }
    .input-btn.elegant { top: calc(50% - 45px); left: 80%; border-color: var(--c-elegant); }
    .input-btn.brave { top: calc(85% - 45px); left: 80%; border-color: var(--c-brave); }
    
    .input-btn.mystic:active, .input-btn.mystic.active { box-shadow: 0 0 25px var(--c-mystic); background: rgba(16, 185, 129, 0.2); }
    .input-btn.elegant:active, .input-btn.elegant.active { box-shadow: 0 0 25px var(--c-elegant); background: rgba(168, 85, 247, 0.2); }
    .input-btn.brave:active, .input-btn.brave.active { box-shadow: 0 0 25px var(--c-brave); background: rgba(239, 68, 68, 0.2); }

    .btn-icon {
        width: 64px;
        height: 64px;
        background-image: url('../assets/images/icon/icon_sheet_01_minigame_ui.webp');
        background-size: 800% 800%;
        image-rendering: pixelated;
    }
    .input-btn.mystic .btn-icon { background-position: 28.571% 42.857%; }
    .input-btn.elegant .btn-icon { background-position: 14.285% 42.857%; }
    .input-btn.brave .btn-icon { background-position: 0% 42.857%; }

    /* Notes Layer */
    #notes-layer {
        position: absolute;
        inset: 0;
        z-index: 20;
        pointer-events: none;
    }

    .note {
        position: absolute;
        width: 72px;
        height: 72px;
        margin-top: -36px;
        margin-left: -36px;
        display: flex;
        justify-content: center;
        align-items: center;
        will-change: left;
    }
    
    .note-shape {
        position: absolute;
        font-size: 54px;
        opacity: 0.3;
        z-index: 1;
        filter: blur(1px);
    }
    
    .note.mystic .note-shape { color: var(--c-mystic); text-shadow: 0 0 10px var(--c-mystic); }
    .note.elegant .note-shape { color: var(--c-elegant); text-shadow: 0 0 10px var(--c-elegant); }
    .note.brave .note-shape { color: var(--c-brave); text-shadow: 0 0 10px var(--c-brave); }

    .note-icon {
        position: relative;
        z-index: 2;
        width: 72px;
        height: 72px;
        background-image: url('../assets/images/icon/icon_sheet_01_minigame_ui.webp');
        background-size: 800% 800%;
        image-rendering: pixelated;
        filter: drop-shadow(0 4px 6px rgba(0,0,0,0.5));
        transition: transform 0.1s;
    }

    /* Settings UI */
    #settings-ui {
        position: absolute;
        top: 20px; right: 20px;
        background: var(--glass-bg);
        padding: 20px;
        border-radius: 16px;
        border: 1px solid var(--glass-border);
        z-index: 110;
        display: flex;
        gap: 15px;
        backdrop-filter: blur(12px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }
    
    .control-group { display: flex; flex-direction: column; gap: 6px; }
    .control-group label { font-size: 11px; color: #94a3b8; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; }
    select, input[type="range"] { 
        background: #1e293b; 
        color: white; 
        border: 1px solid var(--glass-border); 
        padding: 6px 12px; 
        border-radius: 6px; 
        outline: none; 
        font-family: inherit;
        font-weight: 600;
        font-size: 14px;
    }
    select:focus {
        border-color: var(--c-elegant);
    }
    input[type="range"] {
        padding: 0;
        height: 8px;
        cursor: pointer;
        accent-color: var(--c-elegant);
    }

    .range-val-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .range-val {
        font-size: 12px;
        color: #cbd5e1;
        font-weight: 600;
    }

    .btn-primary { 
        background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%); 
        color: white; 
        border: none; 
        padding: 8px 24px; 
        border-radius: 8px; 
        cursor: pointer; 
        font-weight: 800; 
        font-size: 15px;
        letter-spacing: 1px;
        transition: transform 0.2s, box-shadow 0.2s; 
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
        align-self: flex-end;
    }
    .btn-primary:hover { 
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(59, 130, 246, 0.4);
    }
    .btn-primary:active {
        transform: translateY(1px);
    }

    .btn-secondary {
        background: rgba(255, 255, 255, 0.1);
        color: white;
        border: 1px solid var(--glass-border);
        padding: 8px 16px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 800;
        font-size: 15px;
        transition: background 0.2s;
        align-self: flex-end;
    }
    .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.2);
    }
    
    /* HUD */
    #hud {
        position: absolute;
        top: 20px; left: 20px;
        z-index: 100;
        background: var(--glass-bg);
        padding: 12px 24px;
        border-radius: 16px;
        font-size: 22px;
        font-weight: 800;
        display: flex;
        gap: 25px;
        border: 1px solid var(--glass-border);
        backdrop-filter: blur(12px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }
    #hud span {
        color: #38bdf8;
    }
    #combo-container {
        position: relative;
    }
    #combo-val.bump {
        animation: comboBump 0.15s ease-out;
    }
    @keyframes comboBump {
        0% { transform: scale(1); }
        50% { transform: scale(1.3); color: #f43f5e; }
        100% { transform: scale(1); }
    }

    /* Floating Feedback Text */
    .hit-text {
        position: absolute;
        font-weight: 900;
        font-size: 56px;
        text-shadow: 0 4px 10px rgba(0,0,0,0.9);
        pointer-events: none;
        animation: floatUpFade 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
        z-index: 40;
        transform: translate(-50%, -50%);
        letter-spacing: 2px;
    }

    @keyframes floatUpFade {
        0% { transform: translate(-50%, 30px) scale(0.6); opacity: 0; }
        15% { transform: translate(-50%, 0px) scale(1.15); opacity: 1; }
        35% { transform: translate(-50%, 0px) scale(1.0); opacity: 1; }
        100% { transform: translate(-50%, -50px) scale(0.9); opacity: 0; }
    }

    /* Hit Rings and Particles */
    .hit-ring {
        position: absolute;
        left: 75%;
        width: 100px;
        height: 100px;
        border-radius: 50%;
        border: 4px solid #fff;
        margin-left: -50px;
        transform: scale(0.5);
        opacity: 1;
        pointer-events: none;
        z-index: 25;
        animation: hitRingBurst 0.3s cubic-bezier(0.1, 0.8, 0.3, 1) forwards;
    }
    @keyframes hitRingBurst {
        0% { transform: scale(0.5); opacity: 1; border-width: 8px; }
        100% { transform: scale(1.6); opacity: 0; border-width: 1px; }
    }

    .sparkle {
        position: absolute;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        pointer-events: none;
        z-index: 26;
        animation: sparkleFade 0.4s cubic-bezier(0.1, 0.8, 0.3, 1) forwards;
    }
    @keyframes sparkleFade {
        0% { transform: translate(0, 0) scale(1); opacity: 1; }
        100% { transform: translate(var(--tx), var(--ty)) scale(0.1); opacity: 0; }
    }

    /* CountDown Overlay */
    #countdown-overlay {
        position: absolute;
        inset: 0;
        background: rgba(2, 6, 23, 0.5);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 150;
        pointer-events: none;
    }
    #countdown-text {
        font-size: 160px;
        font-weight: 900;
        color: #fff;
        text-shadow: 0 0 40px rgba(168, 85, 247, 0.8);
    }
    .countdown-zoom {
        animation: countdownZoom 1.0s cubic-bezier(0.075, 0.82, 0.165, 1) forwards;
    }
    @keyframes countdownZoom {
        0% { transform: scale(2.5); opacity: 0; }
        30% { transform: scale(1); opacity: 1; }
        80% { transform: scale(0.9); opacity: 1; }
        100% { transform: scale(0.7); opacity: 0; }
    }

    /* Modals */
    .modal-overlay {
        position: absolute;
        inset: 0;
        background: rgba(2, 6, 23, 0.8);
        backdrop-filter: blur(15px);
        z-index: 200;
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
    }
    .modal-overlay.active {
        opacity: 1;
        pointer-events: auto;
    }

    .modal-content {
        background: rgba(30, 41, 59, 0.7);
        border: 2px solid var(--glass-border);
        border-radius: 24px;
        padding: 40px;
        width: 600px;
        text-align: center;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.7), 0 0 40px rgba(168, 85, 247, 0.15);
        transform: scale(0.9);
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .modal-overlay.active .modal-content {
        transform: scale(1);
    }

    .modal-title {
        font-size: 36px;
        font-weight: 900;
        margin-bottom: 20px;
        letter-spacing: 2px;
        background: linear-gradient(135deg, #fff 0%, #cbd5e1 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* Result specifics */
    .result-rank {
        font-size: 96px;
        font-weight: 900;
        margin: 10px 0;
        text-shadow: 0 0 30px currentColor;
    }
    .rank-S { color: #facc15; }
    .rank-A { color: #a855f7; }
    .rank-B { color: #3b82f6; }
    .rank-C { color: #10b981; }
    .rank-D { color: #64748b; }

    .result-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 15px;
        margin: 25px 0;
        background: rgba(15, 23, 42, 0.4);
        padding: 20px;
        border-radius: 16px;
        border: 1px solid var(--glass-border);
    }
    .result-item {
        display: flex;
        justify-content: space-between;
        font-size: 18px;
        font-weight: 600;
        color: #94a3b8;
    }
    .result-item span:last-child {
        color: #fff;
        font-weight: 800;
    }
    .result-item.perfect span:last-child { color: #fbbf24; }
    .result-item.great span:last-child { color: #34d399; }
    .result-item.good span:last-child { color: #38bdf8; }
    .result-item.miss span:last-child { color: #f87171; }

    .modal-actions {
        display: flex;
        justify-content: center;
        gap: 20px;
        margin-top: 30px;
    }
    .modal-actions button {
        padding: 12px 30px;
        font-size: 16px;
    }

    /* Pause Menu Specifics */
    .pause-stats {
        margin: 20px 0;
        font-size: 18px;
        color: #cbd5e1;
    }

</style>
</head>
<body>

<div id="game-container">
    <!-- Top Half: Canvas Visualizer -->
    <div id="top-half">
        <canvas id="visualizer-canvas"></canvas>
        <div id="visual-overlay-text">Elegant Rhythm Visualizer</div>
    </div>

    <!-- Bottom Half: Lanes & Portrait -->
    <div id="bottom-half">
        <div id="vocal-portrait-container">
            <canvas id="vocal-canvas"></canvas>
            <div class="vocal-name" id="vocal-tag">SINGER</div>
        </div>
        
        <div id="lane-container">
            <div class="lane-path mystic"></div>
            <div class="lane-path elegant"></div>
            <div class="lane-path brave"></div>
            
            <div id="judgment-line"></div>
            <div id="notes-layer"></div>

            <!-- Input buttons aligned directly with the Judgment Line & Lanes height -->
            <div class="input-btn mystic" data-attr="mystic"><div class="btn-icon"></div></div>
            <div class="input-btn elegant" data-attr="elegant"><div class="btn-icon"></div></div>
            <div class="input-btn brave" data-attr="brave"><div class="btn-icon"></div></div>
        </div>
    </div>

    <!-- Settings Controls UI -->
    <div id="settings-ui">
        <div class="control-group">
            <label>Track</label>
            <select id="track-select"></select>
        </div>
        <div class="control-group">
            <label>Density</label>
            <select id="density-select">
                <option value="1">少ない</option>
                <option value="2" selected>普通</option>
                <option value="3">多い</option>
            </select>
        </div>
        <div class="control-group">
            <label>Mouse Input</label>
            <select id="easy-mouse-select">
                <option value="on" selected>簡易入力 ON</option>
                <option value="off">簡易入力 OFF</option>
            </select>
        </div>
        <div class="control-group">
            <div class="range-val-container">
                <label>Note Speed</label>
                <span class="range-val" id="speed-val">400 px/s</span>
            </div>
            <input type="range" id="note-speed-input" min="200" max="800" value="400" step="50">
        </div>
        <div class="control-group">
            <label>Window</label>
            <select id="window-select">
                <option value="250">大 (±250ms)</option>
                <option value="150" selected>中 (±150ms)</option>
                <option value="80">小 (±80ms)</option>
            </select>
        </div>
        <div class="control-group">
            <div class="range-val-container">
                <label>BGM Volume</label>
                <span class="range-val" id="bgm-vol-val">80%</span>
            </div>
            <input type="range" id="bgm-vol" min="0" max="100" value="80">
        </div>
        <div class="control-group">
            <div class="range-val-container">
                <label>SE Volume</label>
                <span class="range-val" id="se-vol-val">70%</span>
            </div>
            <input type="range" id="se-vol" min="0" max="100" value="70">
        </div>
        <div class="control-group">
            <div class="range-val-container">
                <label>Timing Offset</label>
                <span class="range-val" id="offset-val">0 ms</span>
            </div>
            <input type="range" id="offset" min="-250" max="250" value="0" step="5">
        </div>
        <button id="play-btn" class="btn-primary">PLAY</button>
    </div>

    <!-- HUD -->
    <div id="hud">
        <div>SCORE: <span id="score-val">0</span></div>
        <div id="combo-container">COMBO: <span id="combo-val">0</span></div>
        <div>TIME: <span id="time-val">0.00</span></div>
    </div>
</div>

<!-- Countdown Overlay -->
<div id="countdown-overlay">
    <div id="countdown-text">3</div>
</div>

<!-- Pause Modal -->
<div id="pause-modal" class="modal-overlay">
    <div class="modal-content">
        <div class="modal-title">PAUSED</div>
        <div class="pause-stats">
            Score: <span id="pause-score">0</span> | Combo: <span id="pause-combo">0</span>
        </div>
        <div class="modal-actions">
            <button id="resume-btn" class="btn-primary">RESUME</button>
            <button id="restart-btn" class="btn-secondary">RESTART</button>
            <button id="exit-btn" class="btn-secondary">EXIT</button>
        </div>
    </div>
</div>

<!-- Results Modal -->
<div id="results-modal" class="modal-overlay">
    <div class="modal-content">
        <div class="modal-title">STAGE CLEAR</div>
        <div id="res-rank" class="result-rank rank-S">S</div>
        
        <div class="result-grid">
            <div class="result-item perfect">
                <span>PERFECT</span>
                <span id="res-perfect">0</span>
            </div>
            <div class="result-item great">
                <span>GREAT</span>
                <span id="res-great">0</span>
            </div>
            <div class="result-item good">
                <span>GOOD</span>
                <span id="res-good">0</span>
            </div>
            <div class="result-item miss">
                <span>MISS</span>
                <span id="res-miss">0</span>
            </div>
            <div class="result-item">
                <span>MAX COMBO</span>
                <span id="res-maxcombo">0</span>
            </div>
            <div class="result-item">
                <span>TOTAL SCORE</span>
                <span id="res-score" style="color: #38bdf8;">0</span>
            </div>
        </div>
        
        <div class="modal-actions">
            <button id="res-retry-btn" class="btn-primary">RETRY</button>
            <button id="res-close-btn" class="btn-secondary">CLOSE</button>
        </div>
    </div>
</div>

<audio id="bgm-player" style="display:none;"></audio>

<script src="rhythm_data.js"></script>
<script>
// --- Audio Pool for CORS-Free Playback on file:// ---
const SE_POOL_SIZE = 8;
const sePool = [];
let sePoolIndex = 0;
const SE_FILE_PATH = '../assets/audio/se/0200_rune_flash.mp3';

const player = document.getElementById('bgm-player');
let tracksData = [];
let songEmotionsData = {};
const AUDIO_BASE_DIR = '../assets/audio/vocal/';
const SPRITE_BASE_DIR = '../assets/images/game/';

// State
let isPlaying = false;
let isPaused = false;
let isCountingDown = false;
let currentNotes = [];
let score = 0;
let combo = 0;
let maxCombo = 0;
let perfects = 0, greats = 0, goods = 0, misses = 0;

// Game Time (Supports minus/negative time values for visual countdown flow)
let gameTime = 0;
let gameStartTime = 0;

// Config
let noteSpeed = 400; // pixels per second
const JUDGMENT_X_RATIO = 0.75; 

// Elements
const scoreValEl = document.getElementById('score-val');
const comboValEl = document.getElementById('combo-val');
const timeValEl = document.getElementById('time-val');
